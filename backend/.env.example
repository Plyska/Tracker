# Tracker backend — приклад env. Скопіюй у `.env` і заповни.
# Реальний `.env` у git НЕ потрапляє (.gitignore).

# --- База даних (Neon PostgreSQL) ---
# Pooled connection (runtime). Приклад Neon: ...-pooler.<region>.neon.tech/...?sslmode=require
DATABASE_URL="postgresql://user:password@host-pooler.region.neon.tech/tracker?sslmode=require"
# Direct connection (для prisma migrate). Без пулера.
DIRECT_URL="postgresql://user:password@host.region.neon.tech/tracker?sslmode=require"

# --- Auth ---
# Секрет для підпису access-JWT (>= 32 символи). Згенеруй: openssl rand -base64 48
# У ПРОДІ плейсхолдер нижче заборонено — сервер не стартує (env.ts guard).
JWT_ACCESS_SECRET="change-me-access-secret"
# (Опційно) попередній секрет для zero-downtime ротації: старий секрет сюди, новий — у
# JWT_ACCESS_SECRET; старі живі токени валідуються ще ~ACCESS_TOKEN_TTL. Прибрати після вікна.
# JWT_ACCESS_SECRET_PREVIOUS=""
# TTL токенів
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# --- HTTP ---
PORT="3000"
NODE_ENV="development"
# Дозволений origin фронтенду (CORS, credentials). Кома-розділений список.
CORS_ORIGIN="http://localhost:5173"
