// Tracker — схема БД. Дзеркалить доменні моделі (docs/data-models.md) і контракт
// (docs/api-contract.md). `plan` НЕ зберігається — похідне від підписки (mapper повертає 'pro'
// на час релізу; монетизація — пізніша фаза).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7: конект-URL більше не тут — рантайм через driver adapter (src/prisma.ts),
  // міграції/CLI — через prisma.config.ts (datasource.url = DIRECT_URL).
  provider = "postgresql"
}

enum Role {
  user
  admin
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  avatarUrl    String?
  passwordHash String? // null = OAuth-only акаунт (шов на майбутнє)
  role         Role     @default(user)
  createdAt    DateTime @default(now())

  habits        Habit[]
  refreshTokens RefreshToken[]
  dailyLogs     DailyLog[]
}

model Habit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String
  icon      String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  entries HabitEntry[]

  @@index([userId])
}

model HabitEntry {
  id      String  @id @default(cuid())
  habitId String
  habit   Habit   @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date    String // 'YYYY-MM-DD' — рядок, матчить ISO-інваріант контракту (без TZ-пасток)
  done    Boolean @default(true)

  // Унікальний ключ запису (habitId+date) — основа upsert у PUT /entries
  @@unique([habitId, date])
  @@index([habitId])
}

// Щоденний настрій/нотатки (docs/data-models.md). Окремий ЖЦ від HabitEntry: про день у цілому,
// не про звичку. Sparse — один запис на день. Передумова mood-кореляції (stats).
model DailyLog {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String // 'YYYY-MM-DD' — той самий ISO-інваріант (без TZ-пасток)
  mood   Int // 1–5 (валідація на вході zod-схемою)
  notes  String?

  // Унікальний ключ (userId+date) — основа upsert у PUT /daily-logs
  @@unique([userId, date])
  @@index([userId])
}

// Refresh-токени: ротація + reuse-detection. Зберігаємо лише SHA-256 хеш непрозорого токена.
// При повторному використанні відкликаного токена відкликаємо всю `family` (захист від крадіжки).
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    String // спільний id ланцюга ротації
  tokenHash String    @unique // sha256(opaque token)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([family])
}
